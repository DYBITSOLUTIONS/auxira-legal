<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Términos y Condiciones — Auxira</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #07071a;
      --surface: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.08);
      --text: #e8e8f0;
      --muted: #7777aa;
      --accent-blue: #60a5fa;
      --accent-purple: #a78bfa;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* TOP BAR */
    .topbar {
      width: 100%;
      padding: 18px 32px;
      display: flex;
      align-items: center;
      gap: 14px;
      border-bottom: 1px solid var(--border);
      background: rgba(7,7,26,0.85);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .topbar a {
      font-size: 0.82rem;
      color: var(--muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .topbar a:hover { color: var(--accent-purple); }
    .topbar-sep { color: var(--border); font-size: 0.9rem; }
    .topbar-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--accent-purple);
    }

    /* HERO */
    .hero {
      width: 100%;
      padding: 64px 24px 48px;
      text-align: center;
      background: radial-gradient(ellipse at 50% 0%, rgba(167,139,250,0.12) 0%, transparent 65%);
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(167,139,250,0.1);
      border: 1px solid rgba(167,139,250,0.25);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 0.78rem;
      color: var(--accent-purple);
      margin-bottom: 20px;
      font-weight: 500;
    }
    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #c4b5fd, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
    }
    .hero-date { font-size: 0.82rem; color: var(--muted); }

    /* CONTENT */
    .content {
      width: 100%;
      max-width: 780px;
      padding: 48px 24px 80px;
      animation: fadeUp 0.5s ease both;
    }

    .intro-box {
      background: rgba(167,139,250,0.06);
      border: 1px solid rgba(167,139,250,0.18);
      border-radius: 16px;
      padding: 24px 28px;
      margin-bottom: 48px;
      font-size: 0.92rem;
      line-height: 1.75;
      color: #c4b5fd;
    }
    .intro-box strong { color: var(--accent-purple); font-weight: 600; }

    section.block { margin-bottom: 44px; }

    section.block h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--accent-purple);
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(167,139,250,0.15);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    section.block h2 .num {
      background: rgba(167,139,250,0.12);
      border-radius: 8px;
      padding: 2px 9px;
      font-size: 0.8rem;
      color: var(--accent-purple);
      font-weight: 700;
    }

    p {
      font-size: 0.92rem;
      line-height: 1.78;
      color: #c8c8e0;
      margin-bottom: 12px;
    }

    ul {
      list-style: none;
      margin: 10px 0 14px 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    ul li {
      font-size: 0.9rem;
      line-height: 1.7;
      color: #c0c0d8;
      padding-left: 20px;
      position: relative;
    }
    ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 9px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent-purple);
      opacity: 0.6;
    }
    ul li strong { color: #dde; font-weight: 600; }

    .links-list li::before { background: var(--accent-blue); }
    .links-list li a {
      color: var(--accent-blue);
      text-decoration: none;
      font-size: 0.88rem;
      transition: color 0.2s;
    }
    .links-list li a:hover { color: #93c5fd; text-decoration: underline; }

    .disclaimer-box {
      background: rgba(167,139,250,0.07);
      border: 1px solid rgba(167,139,250,0.22);
      border-radius: 14px;
      padding: 20px 24px;
      margin-top: 16px;
    }
    .disclaimer-box p { color: #c4b5fd; font-size: 0.88rem; margin: 0; }

    .warning-box {
      background: rgba(251,191,36,0.06);
      border: 1px solid rgba(251,191,36,0.2);
      border-radius: 14px;
      padding: 18px 22px;
      margin-top: 16px;
    }
    .warning-box p { color: #fde68a; font-size: 0.87rem; margin: 0; line-height: 1.65; }

    footer {
      padding: 28px 24px;
      text-align: center;
      font-size: 0.78rem;
      color: #44445a;
      border-top: 1px solid var(--border);
      width: 100%;
    }
    footer a { color: #6655bb; text-decoration: none; transition: color 0.2s; }
    footer a:hover { color: var(--accent-purple); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.7rem; }
      .content { padding: 36px 16px 60px; }
    }
  </style>
</head>
